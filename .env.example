# TORdex environment configuration
# Copy to .env and adjust as needed.

# === Server ===
TORDEX_HTTP_BIND=0.0.0.0:8080
RUST_LOG=tordex=debug,tower_http=info,sqlx=warn

# === Database (PostgreSQL) ===
DATABASE_URL=postgres://tordex:tordex@localhost:5432/tordex
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT_SECS=5

# === Redis Streams ===
REDIS_URL=redis://localhost:6379
REDIS_STREAM_KEY=tordex:events

# === MinIO / S3 ===
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=tordex
MINIO_SECRET_KEY=tordex-secret
MINIO_REGION=us-east-1
MINIO_BUCKET=tordex-evidence

# === Qdrant ===
QDRANT_URL=http://localhost:6334
QDRANT_API_KEY=

# === Collection defaults ===
TORDEX_HTTP_USER_AGENT=TORdex/0.1 (+https://github.com/tordex)
TORDEX_HTTP_TIMEOUT_SECS=30
TORDEX_HTTP_MAX_REDIRECTS=5
TORDEX_RATE_LIMIT_PER_SEC=5
TORDEX_RATE_LIMIT_BURST=10

# === Browser backend ===
# none | lightpanda | chromium
TORDEX_BROWSER_BACKEND=none
TORDEX_LIGHTPANDA_CDP_URL=ws://localhost:9222